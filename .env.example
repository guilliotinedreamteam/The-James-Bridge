# -------------------------------------------------
# NeuroBridge Environment Configuration
# -------------------------------------------------
# Copy this file to .env and customize as needed.
# All values shown are defaults.

# --- Model Architecture ---
# NB_NUM_TIMESTEPS=100
# NB_NUM_FEATURES=128
# NB_NUM_PHONEMES=41
# NB_LSTM_UNITS=256
# NB_DENSE_UNITS=128

# --- Training ---
# NB_BATCH_SIZE=32
# NB_EPOCHS=5
# NB_LEARNING_RATE=0.001
# NB_TRAIN_SAMPLES=1000

# --- Paths ---
# NB_MODEL_DIR=./models
# NB_MODEL_FILENAME=neurobridge_decoder.keras
# NB_REALTIME_MODEL_FILENAME=neurobridge_realtime.keras

# --- Data (replace with real data paths) ---
# NB_ECOG_DATA_DIR=/path/to/your/real_ecog_data/
# NB_PHONEME_LABELS_FILE=/path/to/your/real_phoneme_labels.csv

# --- API Server ---
# NB_API_HOST=0.0.0.0
# NB_API_PORT=5000
# NB_API_DEBUG=false

# --- Audio ---
# NB_AUDIO_SAMPLE_RATE=16000
# NB_PHONEME_DURATION=0.1

# --- Logging ---
# LOG_LEVEL=INFO
